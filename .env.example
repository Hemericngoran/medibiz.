# Port du serveur (Railway le configure automatiquement)
PORT=3001

# Clé secrète JWT (CHANGE CETTE VALEUR !)
JWT_SECRET=medibiz-votre-cle-secrete-unique-2025

# ── CONFIGURATION EMAIL (Notifications) ──
# Pour Gmail : activer "Authentification à 2 facteurs"
# puis créer un "Mot de passe d'application" dans les paramètres Google

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=mot-de-passe-application-gmail
SMTP_FROM=MediBiz Manager <noreply@medibiz.ci>
ADMIN_EMAIL=destinataire-alertes@email.com
